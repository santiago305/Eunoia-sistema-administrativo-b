# Desarrollo local del backend. Copiar como .env y ajustar sólo si es necesario.
PORT=3000
NODE_ENV=development
APP_COMPANY_NAME=Eunoia
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
COOKIE_DOMAIN=

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=eunoia-local-postgres
DB_NAME=EunoiaDB

COOKIE_SECRET=local-cookie-secret-change-before-production-1234
JWT_SECRET=local-jwt-secret-change-before-production-123456
JWT_EXPIRES_IN=3600s
JWT_ISSUER=eunoia-local
JWT_REFRESH_EXPIRES_IN=7d
MASTER_ADMIN_INITIAL_PASSWORD=DevMaster_ChangeMe123!

# Proveedores de identidad: mantener vacíos hasta configurar credenciales propias.
IDENTITY_API_KEY=
IDENTITY_BASE_URL=
IDENTITY_API_DIURVAN_KEY=
IDENTITY_BASE_DIURVAN_URL=
IDENTITY_API_DECOLECTA_KEY=
IDENTITY_BASE_DECOLECTA_URL=
IDENTITY_TIMEOUT_MS=4000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=eunoia-local-redis
REDIS_DB=0
REDIS_TTL_MS=60000

# Almacenamiento de correo y base de eliminados.
MAIL_STORAGE_ACTIVE_DIR=storage/mail-attachments
MAIL_STORAGE_DELETED_DIR=storage/mail-attachments-deleted
MAIL_DELETED_DB_HOST=localhost
MAIL_DELETED_DB_PORT=5432
MAIL_DELETED_DB_USERNAME=postgres
MAIL_DELETED_DB_PASSWORD=
MAIL_DELETED_DB_NAME=eunoia_deleted
MAIL_DELETED_RETENTION_DAYS=15
MAIL_DISABLED_USER_RETENTION_DAYS=30
